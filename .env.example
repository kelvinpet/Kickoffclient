# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Backend scripts
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI
GROQ_API_KEY=

# Payments
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=

# (optional) ID of the Flutterwave payment plan to subscribe customers to
# defaults to 155339 if unset
# you can also override this per-request by sending `plan_id` in the
# body of the flutterwave-checkout POST; useful when testing with a
# plan created in Flutterwave's test mode.
FLUTTERWAVE_PLAN_ID=155339
